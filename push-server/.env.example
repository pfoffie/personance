# Required — generate with: npm run generate-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Contact email used in the VAPID subject (must start with mailto:)
VAPID_SUBJECT=mailto:admin@example.com

# Port to listen on (default: 3000)
PORT=3000

# How often to check for due reminders in milliseconds (default: 60000)
PUSH_INTERVAL_MS=60000

# Directory to store subscription data (default: ./data)
DATA_DIR=./data

# Comma-separated list of allowed origins, or * to allow all (default: *)
# Example: ALLOWED_ORIGINS=https://yourapp.example.com
ALLOWED_ORIGINS=*
